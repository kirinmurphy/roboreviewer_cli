{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "bin/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts"
  ]
}
